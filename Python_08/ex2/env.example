# .env.example
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# WARNING: Never commit your .env file to version control.
# This file (.env.example) is safe to commit — it contains no real secrets.

# Application mode: "development" or "production"
MATRIX_MODE=development

# Database connection string
# Examples:
#   SQLite  (local):    sqlite:///local_matrix.db
#   PostgreSQL:         postgresql://user:password@localhost:5432/matrix_db
DATABASE_URL=sqlite:///local_matrix.db

# Secret API key for external services
# Replace with your actual key — never use this placeholder in production
API_KEY=your_secret_api_key_here

# Logging verbosity
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# URL for the Zion resistance network endpoint
ZION_ENDPOINT=http://localhost:8080/zion
